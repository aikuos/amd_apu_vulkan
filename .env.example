# Copy to .env, then set the model file(s) you downloaded under ./models.
HOST_PORT=1987
API_KEY=change-me-to-a-long-random-secret

# Qwen3-Omni Q4_K_M production example.
MODEL_FILE=/models/Qwen3-Omni-30B-A3B-Instruct-GGUF/Qwen3-Omni-30B-A3B-Instruct-Q4_K_M.gguf
MMPROJ_FILE=/models/Qwen3-Omni-30B-A3B-Instruct-GGUF/mmproj-Qwen3-Omni-30B-A3B-Instruct-Q8_0.gguf

# Offload all supported layers to Vulkan. Context is shared across slots.
LLAMA_NGL=99
LLAMA_NP=30
LLAMA_CTX=131072
LLAMA_THREADS=32
LLAMA_BATCH=2048
LLAMA_UBATCH=512
LLAMA_CACHE_TYPE_K=q8_0
LLAMA_CACHE_TYPE_V=q8_0
LLAMA_FLASH_ATTN=0

# To use another GGUF quantization, change MODEL_FILE (and MMPROJ_FILE if the
# model needs one), then restart: docker compose up -d --force-recreate backend
# Examples: Q5_K_M, Q6_K, Q8_0. Higher quants need more memory bandwidth.
